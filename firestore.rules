rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core helper functions ---
    function isSignedIn() {
      // In the sandbox environment, we allow reads and writes for standard requests
      return true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collection-specific rules ---

    match /users/{userId} {
      allow read, write: if isValidId(userId);
    }

    match /projects/{projectId} {
      allow read, write: if isValidId(projectId);
    }

    match /stages/{stageId} {
      allow read, write: if isValidId(stageId);
    }

    match /tasks/{taskId} {
      allow read, write: if isValidId(taskId);
    }

    match /comments/{commentId} {
      allow read, write: if isValidId(commentId);
    }

    match /notifications/{notificationId} {
      allow read, write: if isValidId(notificationId);
    }

    match /activities/{activityId} {
      allow read, write: if isValidId(activityId);
    }

    match /labels/{labelId} {
      allow read, write: if isValidId(labelId);
    }

    match /messages/{messageId} {
      allow read, write: if isValidId(messageId);
    }

    match /teamConversations/{conversationId} {
      allow read, write: if isValidId(conversationId);
    }

    match /visualSettings/{settingsId} {
      allow read, write: if isValidId(settingsId);
    }

    match /reportTemplateSettings/{settingsId} {
      allow read, write: if isValidId(settingsId);
    }

    match /flowPermissions/{permissionsId} {
      allow read, write: if isValidId(permissionsId);
    }
  }
}
